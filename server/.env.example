# ─────────────────────────────────────────────────────────────
# BookVerse Server — Environment Variables
# Copy this file to .env and fill in your values.
# Variables marked [REQUIRED] must be set or the server will
# refuse to start. Variables marked [PROD REQUIRED] are also
# enforced when NODE_ENV=production.
# ─────────────────────────────────────────────────────────────

# ─── Core ─────────────────────────────────────────────────────
NODE_ENV=development          # Set to "production" for production
PORT=5000

# ─── Database [REQUIRED] ──────────────────────────────────────
# Local:
# MONGODB_URI=mongodb://localhost:27017/bookverse
# Atlas (production):
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/bookverse?retryWrites=true&w=majority

# ─── JWT [REQUIRED] ───────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Minimum 32 characters — the server will exit on startup if shorter.
JWT_SECRET=your_jwt_secret_minimum_32_characters_long
JWT_EXPIRE=24h

# ─── Google OAuth [PROD REQUIRED] ─────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Development:
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
# Production: https://your-backend-domain.com/api/auth/google/callback
# Must match an Authorized Redirect URI in Google Cloud Console exactly.

# ─── Google APIs ──────────────────────────────────────────────
GOOGLE_BOOKS_API_KEY=your_google_books_api_key
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# ─── Cloudinary [REQUIRED] ────────────────────────────────────
# Get from: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── CORS [REQUIRED] ──────────────────────────────────────────
# Must match your frontend origin exactly — no trailing slash.
# Development:
FRONTEND_URL=http://localhost:3000
# Production example: https://bookverse.vercel.app

# ─── Cookies (production only) ────────────────────────────────
# Set only when frontend and backend share a parent domain,
# e.g. api.bookverse.com + app.bookverse.com -> .bookverse.com
# Leave unset if they are on different domains.
# COOKIE_DOMAIN=.your-domain.com

# ─── Email [PROD REQUIRED] ────────────────────────────────────
# Leave all SMTP_* unset in development to fall back to console logging.
# Gmail: use an App Password (Google Account -> Security -> App passwords).
# SendGrid: set SMTP_USER=apikey and SMTP_PASS=your_sendgrid_api_key.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password
SMTP_FROM=noreply@bookverse.com

# ─── Admin [PROD REQUIRED] ────────────────────────────────────
# Receives contact form submissions.
ADMIN_EMAIL=your_admin_email@gmail.com
