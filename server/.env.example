# ==============================
# BookVerse Server Configuration
# ==============================
# Copy this file to .env and fill in your values
# cp .env.example .env

# --- Server ---
NODE_ENV=production
PORT=5000

# --- Database ---
# Local: mongodb://127.0.0.1:27017/bookverse
# Atlas: mongodb+srv://<user>:<pass>@cluster.xxxxx.mongodb.net/bookverse?retryWrites=true&w=majority
MONGODB_URI=

# --- JWT ---
# Generate a secure random string: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRE=24h

# --- Frontend URL (for CORS) ---
# Your deployed client URL, e.g. https://bookverse.onrender.com
FRONTEND_URL=

# --- Google OAuth ---
# Get credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# --- Google Books API ---
# Get API key at https://console.cloud.google.com/apis/credentials
GOOGLE_BOOKS_API_KEY=

# --- Cloudinary ---
# Get credentials at https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Email (Nodemailer) ---
# For Gmail: use an App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@bookverse.com

# --- Admin ---
ADMIN_EMAIL=
